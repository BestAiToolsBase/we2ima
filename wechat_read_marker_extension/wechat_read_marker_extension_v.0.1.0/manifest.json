{
  "manifest_version": 3,
  "name": "WeChat Read Marker",
  "version": "0.1.0",
  "description": "Reports WeChat Official Account article reading sessions to the local read-marker API.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:17301/*",
    "http://127.0.0.1:17301/*",
    "*://mp.weixin.qq.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://mp.weixin.qq.com/s/*",
        "*://mp.weixin.qq.com/s?*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
